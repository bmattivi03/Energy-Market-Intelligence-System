# Copy this file to .env and fill in your token before running ingestion.
# Ingestion is OPTIONAL: the repo ships data/ and checkpoints/, so the headline
# numbers reproduce without it.

# ENTSO-E Transparency Platform API token.
# Request one (free) at https://transparency.entsoe.eu/ under My Account Settings.
ENTSOE_TOKEN=

# Optional: force CPU for the imputation pipeline (otherwise CUDA -> MPS -> CPU).
# EMIS_FORCE_CPU=0

# Optional: enable the MPS CPU fallback on Apple Silicon for the imputer.
# PYTORCH_ENABLE_MPS_FALLBACK=1
